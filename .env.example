# ── Pipeline Behaviour ────────────────────────────────────────────────────
REMOVE_ARTIFACTS=true           # Exclude known GrLivArea outliers from training
LOG_TRANSFORM_TARGET=true       # Log-transform SalePrice before modelling
ANOMALY_CONTAMINATION=0.02      # Isolation Forest contamination rate
FORCE_RERUN=false               # Re-run even if same dataset hash seen before

# ── Infrastructure ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
API_KEY=changeme                # Protects mutation endpoints
GRAFANA_PASSWORD=admin

# ── MLflow ────────────────────────────────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=ames-housing

# ── No LLM section. No cloud section. Nothing that requires an account. ──
