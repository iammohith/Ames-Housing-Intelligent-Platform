# Environment Configuration for Ames Housing Intelligence Platform
# Copy to .env and customize for your environment
# All settings below have sensible defaults - only change if needed

# ── API Configuration ─────────────────────────────────────────────────────
API_KEY=changeme
# Used by: POST /pipeline/run, DELETE /pipeline/cancel, mutation endpoints
# Security: Change immediately in production

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL_SYNC=postgresql://ames:ames@postgres:5432/ames
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Paths ─────────────────────────────────────────────────────────────────
ARTIFACTS_DIR=/app/artifacts          # Models, scalers, encoders stored here
CHROMA_PATH=/app/chroma               # RAG vector store

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR, CRITICAL
STRUCTURED_LOG=true                   # JSON log format

# ── Monitoring ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── MLflow ────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=ames-housing

# ── Streamlit (Dashboard) ─────────────────────────────────────────────────
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── Pipeline Behavior ─────────────────────────────────────────────────────
REMOVE_ARTIFACTS=true                 # Exclude known outliers (GrLivArea)
LOG_TRANSFORM_TARGET=true             # Log-transform SalePrice
ANOMALY_CONTAMINATION=0.02            # Isolation Forest contamination rate
FORCE_RERUN=false                     # Re-run even if same dataset seen

# ── No API keys needed. 100% offline. One command setup. ──────────────────
